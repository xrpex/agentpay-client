{
  "name": "agentpay-client",
  "version": "1.0.0",
  "description": "One-line SDK for AI agents to discover and call AgentPay tools with automatic XRPL x402 payments.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "agentpay", "x402", "xrpl", "xrp", "ai-agent",
    "langchain", "autogen", "crewai", "mcp",
    "pay-per-call", "micropayments", "ai-tools"
  ],
  "author": "AgentPay <officialagentpay@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xrpex/agentpay-client"
  },
  "homepage": "https://agentpay-frontend-theta.vercel.app",
  "bugs": {
    "url": "https://github.com/xrpex/agentpay-client/issues",
    "email": "officialagentpay@gmail.com"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=18" },
  "dependencies": {
    "xrpl": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.14.2"
  }
}
